{
  "name": "group-maker",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "botdiscord",
    "siteweb",
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "npm run dev --workspace=botdiscord",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix",
    "*.{js,ts,json,md}": "prettier --write"
  }
}
